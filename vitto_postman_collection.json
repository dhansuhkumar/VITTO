{
	"info": {
		"name": "Vitto API Collection",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Send OTP",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{BASE_URL}}/api/auth/send-otp",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"auth",
								"send-otp"
							]
						}
					}
				},
				{
					"name": "Verify OTP",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\",\n    \"otp\": \"123456\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{BASE_URL}}/api/auth/verify-otp",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"auth",
								"verify-otp"
							]
						}
					}
				}
			]
		},
		{
			"name": "Leads",
			"item": [
				{
					"name": "Create Lead",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{TOKEN}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"institution_name\": \"Demo Bank\",\n    \"institution_type\": \"Bank\",\n    \"city\": \"Mumbai\",\n    \"loan_book_size\": \"1000Cr\",\n    \"email\": \"test@example.com\",\n    \"phone\": \"9876543210\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{BASE_URL}}/api/leads",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"leads"
							]
						}
					}
				},
				{
					"name": "Get Lead By ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{TOKEN}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{BASE_URL}}/api/leads/ID_HERE",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"leads",
								"ID_HERE"
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "BASE_URL",
			"value": "http://localhost:3000"
		},
		{
			"key": "TOKEN",
			"value": "YOUR_JWT_HERE"
		}
	]
}
